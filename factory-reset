#!/bin/bash
# KLIPkey Factory Reset Utility

BRIDGE_PATH="/mnt/klipdata"
TEMPLATE_DIR="$HOME/klipkey/templates"

echo "WARNING: This will overwrite all current printer configurations."
read -p "Are you sure you want to proceed? (y/N): " confirm

# Corrected Logic: Handles 'y', 'Y', 'yes', 'YES', etc.
if [[ "$confirm" =~ ^[yY](es|ES)?$ ]]; then
    echo "Performing factory reset..."

    # Clear existing files (Wildcard outside quotes)
    sudo rm -rf "${BRIDGE_PATH:?}"/*

    # Re-populate from templates
    if [ -d "$TEMPLATE_DIR" ]; then
        cp -r "$TEMPLATE_DIR"/* "$BRIDGE_PATH/"
        echo "Configuration restored from templates."
    else
        echo "Error: Template directory not found."
        exit 1
    fi

    echo "Reset complete. Restarting Klipper..."
    sudo systemctl restart klipper
else
    echo "Reset aborted."
fi
