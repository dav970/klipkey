#!/bin/bash
# KLIPkey Factory Reset Utility
BRIDGE_PATH="/mnt/klipdata"
TEMPLATE_DIR="$HOME/klipkey/templates"

# --- Bridge Check ---
if [ ! -d "$BRIDGE_PATH" ]; then
    echo "ERROR: Factory Reset is only valid for Flash Drive built from Custom Image."
    echo "Bridge mount (/mnt/klipdata) not detected."
    exit 1
fi

echo "WARNING: This will overwrite all current printer configurations."
read -p "Are you sure you want to proceed? (y/N): " confirm

if [[ "$confirm" =~ ^[yY](es|ES)?$ ]]; then
    sudo rm -rf "${BRIDGE_PATH:?}"/*
    cp -r "$TEMPLATE_DIR"/* "$BRIDGE_PATH/"
    sudo systemctl restart klipper
else
    echo "Reset aborted."
fi
