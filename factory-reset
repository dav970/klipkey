#!/bin/bash
# KLIPkey Factory Reset Utility
# Reverts bridge configurations to template defaults

BRIDGE_PATH="/mnt/klipdata"
TEMPLATE_DIR="$HOME/klipkey/templates"

echo "WARNING: This will overwrite all current printer configurations."
read -p "Are you sure you want to proceed? (y/N) " confirm

if [[ $confirm == [yY] || $confirm == [yY][eE][sS] ]]; then
    echo "Performing factory reset..."

    # 1. Clear existing files (Wildcard OUTSIDE quotes for expansion)
    # Using :? safety to prevent 'rm -rf /*' if BRIDGE_PATH is empty
    sudo rm -rf "${BRIDGE_PATH:?}"/*

    # 2. Re-populate from templates (Double quotes for variable expansion)
    if [ -d "$TEMPLATE_DIR" ]; then
        files=("$TEMPLATE_DIR"/*)
        if [ ${#files[@]} -gt 0 ]; then
            cp -r "$TEMPLATE_DIR"/* "$BRIDGE_PATH/"
            echo "Configuration restored from templates."
        else
            echo "Warning: Template directory is empty."
        fi
    else
        echo "Error: Template directory not found at $TEMPLATE_DIR"
        exit 1
    fi

    echo "Reset complete. Restarting Klipper services..."
    sudo systemctl restart klipper
else
    echo "Reset aborted."
fi
