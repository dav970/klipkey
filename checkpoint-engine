#!/bin/bash
# KLIPkey Checkpoint Engine
# Manages configuration backups and restores

BACKUP_DIR="$HOME/klipkey/backups"
CONFIG_DIR="/mnt/klipdata"
mkdir -p "$BACKUP_DIR"

echo "--- KLIPkey Checkpoint Management ---"
echo "1) Create New Checkpoint"
echo "2) Restore from Checkpoint"
echo "3) Delete Old Checkpoints"
read -p "Select action: " action

case $action in
    1)
        TIMESTAMP=$(date +%Y%m%d_%H%M%S)
        tar -czf "$BACKUP_DIR/backup_$TIMESTAMP.tar.gz" -C "$CONFIG_DIR" .
        echo "Checkpoint created: backup_$TIMESTAMP.tar.gz"
        ;;
    2)
        # Get list of backups
        ZIPS=($(ls "$BACKUP_DIR"/*.tar.gz 2>/dev/null))
        if [ ${#ZIPS[@]} -eq 0 ]; then
            echo "No checkpoints found."
            exit 1
        fi

        echo "Available Checkpoints:"
        for i in "${!ZIPS[@]}"; do
            echo "$((i+1))) $(basename "${ZIPS[$i]}")"
        done

        read -p "Select archive to RESTORE: " choice

        # Copilot Fix: Validate that input is a number
        if [[ ! "$choice" =~ ^[0-9]+$ ]]; then
            echo "Error: Invalid input. Please enter a number."
            exit 1
        fi

        INDEX=$((choice - 1))
        SELECTED_ZIP="${ZIPS[$INDEX]}"

        if [ -z "$SELECTED_ZIP" ] || [ ! -f "$SELECTED_ZIP" ]; then
            echo "Error: Selection out of range."
            exit 1
        fi

        # Perform Restore
        echo "Restoring $SELECTED_ZIP..."
        sudo rm -rf "$CONFIG_DIR"/*
        sudo tar -xzf "$SELECTED_ZIP" -C "$CONFIG_DIR"

        # Copilot Fix: Check if config exists before updating hash
        KLIP_CFG="$HOME/klipkey/klipkey.cfg"
        if [ -f "$KLIP_CFG" ]; then
            sed -i "s/^audit_hash=.*/audit_hash=RESTORED_STALE/" "$KLIP_CFG"
            echo "Audit hash updated to RESTORED_STALE."
        else
            echo "Warning: klipkey.cfg not found. Skipping hash update."
        fi
        
        echo "Restore complete. Restarting services..."
        sudo systemctl restart klipper
        ;;
    3)
        echo "Cleaning up backups older than 7 days..."
        find "$BACKUP_DIR" -name "*.tar.gz" -mtime +7 -delete
        echo "Cleanup complete."
        ;;
    *)
        echo "Invalid selection."
        ;;
esac
