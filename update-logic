#!/bin/bash
# KLIPkey Portable Update & Installer Logic

# 1. Detect Environment
USER_HOME=$HOME
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "Initializing KLIPkey for user: $USER"
echo "Repo detected at: $REPO_DIR"

# 2. Configuration Initialization
if [ ! -f "$REPO_DIR/klipkey.cfg" ]; then
    echo "Creating klipkey.cfg from template..."
    cp "$REPO_DIR/klipkey.cfg.template" "$REPO_DIR/klipkey.cfg"
fi

# 3. Path Synchronization (The Portability Fix)
# This swaps any hardcoded /home/user/ with the actual current home path
echo "Synchronizing internal paths..."
find "$REPO_DIR/patches" -type f -exec sed -i "s|/home/user/|$USER_HOME/|g" {} +
find "$REPO_DIR" -maxdepth 1 -type f -exec sed -i "s|/home/user/|$USER_HOME/|g" {} +

# 4. Systemd Service Installation
if [ -f "$REPO_DIR/patches/klipkey-cursor.service" ]; then
    sudo cp "$REPO_DIR/patches/klipkey-cursor.service" /etc/systemd/system/
    sudo systemctl daemon-reload
    sudo systemctl enable klipkey-cursor.service
    echo "Systemd service updated."
fi

# 5. Permissions Enforcement
chmod +x "$REPO_DIR/launcher"
chmod +x "$REPO_DIR/repair-engine"
chmod +x "$REPO_DIR/gcode-guard"
chmod +x "$REPO_DIR/file-picker"
chmod +x "$REPO_DIR/patches/"*.sh

echo -e "\033[0;32mKLIPkey Update & Portability Fix Complete.\033[0m"
