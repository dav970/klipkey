#!/bin/bash
# KLIPkey Update & Sync Logic V1.2

# 1. Initialize Configuration (The Template Logic)
# ------------------------------------------------
if [ ! -f ~/klipkey/klipkey.cfg ]; then
    echo "Creating klipkey.cfg from template..."
    cp ~/klipkey/klipkey.cfg.template ~/klipkey/klipkey.cfg
fi

source ~/klipkey/klipkey.cfg

# 2. System Service Installation
# ------------------------------------------------
# Ensure the patch service is installed in the system root
if [ -f "~/klipkey/patches/klipkey-cursor.service" ]; then
    sudo cp ~/klipkey/patches/klipkey-cursor.service /etc/systemd/system/
    sudo systemctl daemon-reload
    sudo systemctl enable klipkey-cursor.service
fi

# 3. KlipperScreen UI Patching (Hard Override)
# ------------------------------------------------
# This forces your custom shutdown panel into the active KS directory
if [ -d "~/KlipperScreen" ] && [ -f "~/klipkey/patches/shutdown.py" ]; then
    # Backup original only if a backup doesn't already exist
    if [ ! -f "~/KlipperScreen/panels/shutdown.py.bak" ]; then
        cp ~/KlipperScreen/panels/shutdown.py ~/KlipperScreen/panels/shutdown.py.bak
    fi
    cp ~/klipkey/patches/shutdown.py ~/KlipperScreen/panels/shutdown.py
fi

# 4. Permissions Enforcement
# ------------------------------------------------
# Avoid 'chmod +x *'. Only target actual scripts.
chmod +x ~/klipkey/launcher
chmod +x ~/klipkey/repair-engine
chmod +x ~/klipkey/gcode-guard
chmod +x ~/klipkey/file-picker
chmod +x ~/klipkey/scripts/*.sh

echo -e "\033[0;32mKLIPkey Update Complete.\033[0m"
