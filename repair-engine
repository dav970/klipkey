#!/bin/bash
# ================================================================= #
# KLIPkey Repair Engine V1.2 - "The Monolith"                       #
# Purpose: Flattens includes, resolves paths, and signs for safety. #
# ================================================================= #

source ~/klipkey/klipkey.cfg

# --- CONFIGURATION ---
GREEN='\033[0;32m'
RED='\033[0;31m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

BRIDGE_CONF="/mnt/klipdata/config/printer.cfg"
WORKING_DIR="/tmp/klipkey_repair"
WORKING_CFG="$WORKING_DIR/printer_flat.cfg"
FINAL_DEST="/mnt/klipdata/config/printer.cfg" 

# --- PRE-FLIGHT: WRITE-PROTECTION CHECK ---
echo -n "Checking Bridge write access... "
if [ ! -w "$FINAL_DEST" ]; then [cite: 3]
    echo -e "${RED}FAILED${NC}"
    echo -e "------------------------------------------------"
    echo -e "ERROR: The USB Bridge (/mnt/klipdata) is Read-Only." [cite: 3]
    echo -e "Attempting to re-mount as Read-Write..."
    sudo mount -o remount,rw /mnt/klipdata 2>/dev/null [cite: 5]
    
    if [ ! -w "$FINAL_DEST" ]; then [cite: 6]
        echo -e "${RED}CRITICAL: Hardware lock detected or filesystem error.${NC}"
        read -p "Press Enter to exit..." [cite: 7]
        exit 1
    fi
    echo -e "${GREEN}Fixed! Proceeding...${NC}"
else
    echo -e "${GREEN}OK${NC}"
fi

mkdir -p "$WORKING_DIR"
echo -e "${CYAN}Starting Repair Engine...${NC}"

# --- PHASE 1: BACKUP ---
if [ -f "$BRIDGE_CONF" ]; then [cite: 8]
    TIMESTAMP=$(date +%Y%m%d_%H%M%S)
    cp "$BRIDGE_CONF" "$BRIDGE_CONF.bak_$TIMESTAMP" [cite: 8]
    echo -e "${GREEN}Backup created: printer.cfg.bak_$TIMESTAMP${NC}"
else
    echo -e "${RED}Error: Source printer.cfg not found on Bridge!${NC}"
    exit 1
fi

# --- PHASE 2: RECURSIVE FLATTENER ---
echo -e "${YELLOW}Flattening nested [include] files...${NC}"
> "$WORKING_CFG" 

flatten_config() {
    local current_file="$1"
    local depth="${2:-0}"
    
    if [ "$depth" -gt 10 ]; then [cite: 9]
        echo -e "${RED}!! ERROR: Max include depth (10) reached at $current_file. Skipping.${NC}"
        echo "## ERROR: Circular Include detected at $current_file ##" >> "$WORKING_CFG"
        return
    fi

    local current_dir=$(dirname "$(readlink -f "$current_file")")
    echo "## >>> BEGIN FILE: $current_file <<< ##" >> "$WORKING_CFG"

    while IFS= read -r line || [ -n "$line" ]; do [cite: 10]
        if [[ "$line" =~ ^[[:space:]]*# ]]; then [cite: 11]
            echo "$line" >> "$WORKING_CFG"
            continue
        fi

        if [[ "$line" =~ ^[[:space:]]*\[include[[:space:]]+(.*)\] ]]; then [cite: 12]
            include_path="${BASH_REMATCH[1]}"
            include_path=$(echo "$include_path" | cut -d'#' -f1 | sed 's/[[:space:]]*$//') [cite: 12]

            if [[ "$include_path" != /* ]]; then [cite: 13]
                include_path="$current_dir/$include_path"
            fi
            
            if [ -f "$include_path" ]; then [cite: 14]
                flatten_config "$include_path" $((depth + 1))
            else
                echo "## MISSING INCLUDE: $include_path ##" >> "$WORKING_CFG"
            fi
        else
            echo "$line" >> "$WORKING_CFG" [cite: 15]
        fi
    done < "$current_file"
    echo "## <<< END FILE: $current_file >>> ##" >> "$WORKING_CFG"
}

flatten_config "$BRIDGE_CONF"

# --- PHASE 3: PATH NORMALIZATION ---
echo -e "${YELLOW}Normalizing system paths...${NC}"
sed -i '/^\[virtual_sdcard\]/,/^\[/ s|^path:.*|path: /mnt/klipdata/gcodes|' "$WORKING_CFG" 
sed -i '/^\[save_variables\]/,/^\[/ s|^filename:.*|filename: /mnt/klipdata/config/variables.cfg|' "$WORKING_CFG" 

# --- PHASE 4: MCU MATCHING ---
echo -e "${YELLOW}Phase 4: Hardware Serial Mapping...${NC}"

# Space-safe hardware discovery using mapfile
mapfile -t MAP_SERIALS < <(ls /dev/serial/by-id/* 2>/dev/null)
MAP_CAN=$(ip -brief link show | grep -i can | awk '{print $1}')

if [ ${#MAP_SERIALS[@]} -eq 0 ] && [ -z "$MAP_CAN" ]; then [cite: 17]
    echo -e "${RED}[!] WARNING: No physical hardware detected!${NC}"
else
    CONFIG_MCUS=$(grep -oP '^\[mcu\s*\K[^\]]*' "$WORKING_CFG" | sed 's/^$/main/')
    [ -z "$CONFIG_MCUS" ] && CONFIG_MCUS="main"

    for mcu in $CONFIG_MCUS; do 
        echo -e "\n${CYAN}Configured MCU found: [mcu ${mcu/main/}]${NC}"
        
        declare -a HW_LIST=() 
        local i=1 

        if [ "$mcu" == "main" ]; then [cite: 19]
            CURRENT_ID=$(grep -A 5 "^\[mcu\]" "$WORKING_CFG" | grep -E "serial:|canbus_uuid:" | head -1)
        else
            CURRENT_ID=$(grep -A 5 "^\[mcu $mcu\]" "$WORKING_CFG" | grep -E "serial:|canbus_uuid:" | head -1)
        fi
        
        echo -e "  Current Config: ${YELLOW}$CURRENT_ID${NC}"
        echo -e "  Available Hardware:"

        for hw in "${MAP_SERIALS[@]}"; do [cite: 20]
            echo "    $i) USB: $hw"
            HW_LIST[$i]="serial: $hw"
            ((i++))
        done
        for can in $MAP_CAN; do [cite: 22]
            echo "    $i) CAN Interface: $can"
            HW_LIST[$i]="canbus_uuid: (Enter UUID Manually)" 
            ((i++))
        done
        echo "    s) Skip / Keep Original"

        read -p "  Select hardware to map to [$mcu] (1-$((i-1))/s): " choice

        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -lt "$i" ]; then [cite: 24]
            NEW_VAL="${HW_LIST[$choice]}"
            if [[ "$NEW_VAL" == *"Enter UUID"* ]]; then [cite: 25]
                read -p "    Enter 12-character CAN UUID: " manual_uuid
                NEW_VAL="canbus_uuid: $manual_uuid"
            fi

            if [ "$mcu" == "main" ]; then [cite: 27]
                sed -i "/^\[mcu\]/,/^\[/ s|^\(serial:\|canbus_uuid:\).*|$NEW_VAL|" "$WORKING_CFG" [cite: 28]
            else
                sed -i "/^\[mcu $mcu\]/,/^\[/ s|^\(serial:\|canbus_uuid:\).*|$NEW_VAL|" "$WORKING_CFG" [cite: 29]
            fi
        fi
    done
fi

# --- PHASE 5: DEPLOY & SIGN ---
echo -e "${YELLOW}Finalizing and Signing Configuration...${NC}"
cp "$WORKING_CFG" "$FINAL_DEST"
NEW_HASH=$(sha256sum "$FINAL_DEST" | awk '{print $1}')
sed -i "s/^audit_hash=.*/audit_hash=$NEW_HASH/" ~/klipkey/klipkey.cfg

echo -e "------------------------------------------------"
echo -e "${GREEN}SUCCESS: Repair Complete.${NC}"
echo -e "Signature: ${CYAN}${NEW_HASH:0:12}...${NC}"
read -p "Press Enter to return to Launcher..."
