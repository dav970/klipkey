#!/bin/bash
# KlipKey Repair Engine - Recursive Flattener V1.2

WORKING_CFG="/tmp/printer_flat.cfg"
> "$WORKING_CFG" # Clear existing

# The Recursive Function
flatten_config() {
    local current_file="$1"
    local current_dir=$(dirname "$(readlink -f "$current_file")")

    echo "## --- START OF INCLUDE: $current_file --- ##" >> "$WORKING_CFG"

    while IFS= read -r line || [ -n "$line" ]; do
        # Detect [include ...]
        if [[ "$line" =~ ^\[include\ (.*)\] ]]; then
            include_path="${BASH_REMATCH[1]}"
            
            # Resolve relative paths to Absolute
            if [[ "$include_path" != /* ]]; then
                include_path="$current_dir/$include_path"
            fi
            
            # Recurse if file exists, otherwise comment out error
            if [ -f "$include_path" ]; then
                flatten_config "$include_path"
            else
                echo "# ERROR: Could not find $include_path" >> "$WORKING_CFG"
            fi
        else
            # Pass regular lines through
            echo "$line" >> "$WORKING_CFG"
        fi
    done < "$current_file"
    
    echo "## --- END OF INCLUDE: $current_file --- ##" >> "$WORKING_CFG"
}

# Start the process with the main config on the USB Bridge
if [ -f "/mnt/klipdata/config/printer.cfg" ]; then
    flatten_config "/mnt/klipdata/config/printer.cfg"
else
    echo "Error: No printer.cfg found on Bridge!"
    exit 1
fi

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

CONFIG_DIR="$HOME/printer_data/config"
PRINTER_CFG="$CONFIG_DIR/printer.cfg"
ARCHIVE_DIR="$CONFIG_DIR/archive"
WORKING_CFG="$CONFIG_DIR/printer_working.cfg"
TIMESTAMP=$(date +%Y%m%d_%H%M)

# Load KlipKey State
[ -f ~/klipkey/klipkey.cfg ] && source ~/klipkey/klipkey.cfg || test_mode=false [cite: 12]

mkdir -p "$ARCHIVE_DIR"

# --- PHASE 1: RECURSIVE BACKUP ---
echo -e "${CYAN}Phase 1: Archiving original configuration...${NC}"
mapfile -t INCLUDES < <(grep -RoP '(?<=\[include ).*(?=\])' "$PRINTER_CFG" | sed "s|^|$CONFIG_DIR/|")
zip -j "$ARCHIVE_DIR/RESCUE_BACKUP_$TIMESTAMP.zip" "$PRINTER_CFG" "${INCLUDES[@]}" > /dev/null
echo -e "${GREEN}Backup created: RESCUE_BACKUP_$TIMESTAMP.zip${NC}" [cite: 12]

# --- PHASE 2: MONOLITHIC EXPANSION ---
echo -e "${CYAN}Phase 2: Flattening includes into monolith...${NC}"
expand_includes() {
    local input_file=$1
    while IFS= read -r line; do
        if [[ $line =~ ^\[include\ (.*)\] ]]; then
            include_file="${BASH_REMATCH[1]}"
            # Handle relative paths
            [[ ! "$include_file" =~ ^/ ]] && include_file="$CONFIG_DIR/$include_file"
            echo "# --- BEGIN INCLUDE: $include_file ---"
            expand_includes "$include_file"
            echo "# --- END INCLUDE ---"
        else
            echo "$line"
        fi
    done < "$input_file"
}
expand_includes "$PRINTER_CFG" > "$WORKING_CFG" [cite: 12-15]

# --- PHASE 3: HARDWARE DISCOVERY ---
echo -e "${CYAN}Phase 3: Scanning USB hardware...${NC}"
if [ "$test_mode" = "true" ]; then
    echo -e "${YELLOW}!!! TEST MODE: Using ~/.spoof-mcu !!!${NC}"
    mkdir -p ~/.spoof-mcu
    SYSTEM_SERIALS=($(ls ~/.spoof-mcu/* 2>/dev/null))
else
    SYSTEM_SERIALS=($(ls /dev/serial/by-id/* 2>/dev/null))
fi
CONFIG_MCUS=($(grep -oP '(?<=\[mcu ).*(?=\])' "$WORKING_CFG")) [cite: 16]

# --- PHASE 4: INTERACTIVE REPAIR ---
for MCU in "${CONFIG_MCUS[@]}"; do
    OLD_SERIAL=$(grep -A 5 "\[mcu $MCU\]" "$WORKING_CFG" | grep "serial:" | head -1 | awk '{print $2}')
    
    # Check if currently valid
    if [[ -e "$OLD_SERIAL" ]]; then
        echo -e "${GREEN}[OK] MCU '$MCU' is connected at $OLD_SERIAL${NC}"
        continue
    fi

    echo -e "\n${RED}[CONFLICT] MCU '$MCU' not found!${NC}"
    echo -e "Expected: $OLD_SERIAL"
    echo -e "Available Hardware:"
    for i in "${!SYSTEM_SERIALS[@]}"; do
        printf "  [%d] %s\n" "$((i+1))" "${SYSTEM_SERIALS[$i]}"
    done
    echo "  [D] Disable this MCU (Comment out pins)"
    echo "  [S] Skip / Manual fix later"
    
    read -p "Select action for $MCU: " choice
    
    case $choice in
        [0-9]*)
            NEW_SERIAL="${SYSTEM_SERIALS[$((choice-1))]}"
            sed -i "/\[mcu $MCU\]/,/serial:/ s|serial:.*|serial: $NEW_SERIAL # UPDATED BY KLIPKEY|" "$WORKING_CFG"
            echo -e "${GREEN}Matched $MCU to $NEW_SERIAL${NC}"
            ;;
        [Dd]*)
            # Comment out the MCU block
            sed -i "/\[mcu $MCU\]/,/serial:/ s|^|# KLIPKEY_DISABLED: |" "$WORKING_CFG"
            # --- PHASE 5: PIN NEUTRALIZATION ---
            echo -e "${YELLOW}Neutralizing pins for $MCU...${NC}"
            sed -i "s|^\([^#]*$MCU:\)|# PIN_DISABLED: \1|g" "$WORKING_CFG"
            DISABLED_LIST+=("$MCU")
            ;;
    esac
done [cite: 16-24]

# --- PHASE 6: MACRO AUDIT ---
if [ ${#DISABLED_LIST[@]} -gt 0 ]; then
    echo -e "\n${YELLOW}!!! WARNING: MACRO AUDIT !!!${NC}"
    # Reset the blacklist
    > "$CONFIG_DIR/archive/broken_macros.list"
    for MCU in "${DISABLED_LIST[@]}"; do
        echo -e "Identifying macros referencing missing hardware: $MCU"
        # Extract names of macros that reference the disabled MCU
        grep "$MCU:" "$WORKING_CFG" | grep -v "^#" | xargs -I {} grep -B 20 "{}" "$WORKING_CFG" | grep -oP '(?<=\[gcode_macro ).*(?=\])' | sort -u >> "$CONFIG_DIR/archive/broken_macros.list"
    done
fi [cite: 25-28]

# --- FINALIZATION ---
echo -e "\n${CYAN}Commiting changes?${NC}"
read -p "[Y] to overwrite printer.cfg, [N] to discard: " commit
if [[ "$commit" =~ ^[Yy]$ ]]; then
    cp "$PRINTER_CFG" "$PRINTER_CFG.bak"
    mv "$WORKING_CFG" "$PRINTER_CFG"
    
    # Generate Content-Based Hash of the new unified printer.cfg
    NEW_HASH=$(sha256sum "$PRINTER_CFG" | awk '{print $1}' | head -c 16)
    
    # Sync the hash to klipkey.cfg
    sed -i "s/^audit_hash=.*/audit_hash=$NEW_HASH/" ~/klipkey/klipkey.cfg
    
    # Prepend the hash to the broken_macros.list for the G-Code Guard
    [ -f "$CONFIG_DIR/archive/broken_macros.list" ] && sed -i "1i $NEW_HASH" "$CONFIG_DIR/archive/broken_macros.list"
    
    echo -e "${GREEN}Configuration updated (Hash: $NEW_HASH). Restarting Klipper...${NC}"
    sudo systemctl restart klipper
else
    rm "$WORKING_CFG"
    echo "Changes discarded."
fi [cite: 29-30]
