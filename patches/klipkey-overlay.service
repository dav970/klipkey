[Unit]
Description=KLIPkey Floating Overlay Menu
After=KlipperScreen.service

[Service]
Type=simple
User=user
Environment=DISPLAY=:0.0
# Wait for KlipperScreen to initialize its window
ExecStartPre=/usr/bin/sleep 5
ExecStart=/bin/bash /home/user/klipkey/patches/overlay-menu.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
