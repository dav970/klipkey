#!/bin/bash
# KLIPkey Hardware Discovery Tool
# Dynamically detects CAN interfaces and queries nodes

echo "--- KLIPkey Hardware Discovery ---"

# Find all active CAN interfaces
INTERFACES=$(ip -brief link show | awk '/^can/ || /^vcan/ {print $1}')

if [[ -z "$INTERFACES" ]]; then
    echo "Error: No CAN interfaces (can0, can1, etc.) detected."
    echo "Check your wiring and UDEV rules."
    exit 1
fi

for IFACE in $INTERFACES; do
    echo "Scanning interface: $IFACE..."
    
    # Check if the interface is UP
    if ! ip link show "$IFACE" | grep -q "UP"; then
        echo "  [!] Interface $IFACE is DOWN. Skipping..."
        continue
    fi

    # Query Flashutil/Klipper nodes
    NODES=$(~/klippy-env/bin/python ~/klipper/scripts/canbus_query.py "$IFACE" 2>/dev/null)
    
    if [[ -z "$NODES" || "$NODES" == *"Total available canbus nodes: 0"* ]]; then
        echo "  (No nodes responding on $IFACE)"
    else
        echo "  Found Nodes:"
        echo "$NODES" | grep "canbus_uuid" | sed 's/^/  - /'
    fi
done

echo "----------------------------------"
