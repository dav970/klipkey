#!/bin/bash
# KLIPkey G-Code Safety Guard
# Scans G-Code files for blacklisted macros before execution

TARGET="$1"
BLACKLIST="$HOME/klipkey/blacklist.txt"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

if [[ -z "$TARGET" ]]; then
    echo -e "${RED}Usage: gcode-guard <filename>${NC}"
    exit 1
fi

if [[ ! -f "$BLACKLIST" ]]; then
    echo -e "${GREEN}No blacklist found. Proceeding...${NC}"
    exit 0
fi

echo -e "Scanning $(basename "$TARGET") for restricted macros..."

FOUND_CONFLICTS=0

# Fix: Use Process Substitution < <() to avoid subshell variable loss
while IFS= read -r MACRO || [[ -n "$MACRO" ]]; do
    # Skip empty lines or comments in blacklist
    [[ -z "$MACRO" || "$MACRO" =~ ^# ]] && continue

    # Search for the macro (Case Insensitive)
    if grep -Fqi -- "$MACRO" "$TARGET"; then
        echo -e "${RED}![CONFLICT]: Found restricted macro '$MACRO'${NC}"
        FOUND_CONFLICTS=$((FOUND_CONFLICTS + 1))
    fi
done < <(tail -n +2 "$BLACKLIST")

if [ "$FOUND_CONFLICTS" -gt 0 ]; then
    echo -e "\n${RED}SCAN FAILED: $FOUND_CONFLICTS critical conflicts found.${NC}"
    echo "Execution blocked for safety."
    exit 1
else
    echo -e "\n${GREEN}SCAN PASSED: No restricted macros detected.${NC}"
    exit 0
fi
